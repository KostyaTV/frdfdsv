usd = float(input("Введите сумму в долларах: "))
"""
Выводит сообщение "Введите сумму в долларах: " и позволяет пользователю ввести сумму в долларах.
"""
convert_usd_to_rub = usd * 95.50
"""
Умножает введенное число на 95.50, чтобы получить сумму в рублях.
"""
print("Сумма в рублях: ", convert_usd_to_rub)
"""
Выводит сообщение "Сумма в рублях: " и выводит введенную пользователем сумму в долларах.
"""
