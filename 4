import math

w, h = map(float, input("Введите ширину и высоту прямоугольника: ").split())
calculate_rectangle_area  = w * h
print("Площадь прямоугольника: ", calculate_rectangle_area )

r = float(input("Введите радиус круга: "))
calculate_circle_area = math.pi * r**2
print(f"Площадь круга: {calculate_circle_area:.1f}")
