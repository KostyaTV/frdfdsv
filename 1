#Годовой доход
yi = float(input("Введите годовой доход: "))
#Налоговая ставка
tr = 0.13
#Сумма налога
ta = yi * tr
#Сумма "на руки"
iya = yi - ta
print(f"Общая сумма дохода: {yi:,.2f} руб.")
print(f"Сумма рассчитанного налога: {ta:,.2f} руб.")
print(f"Сумма «на руки» после вычета налога: {iya:,.2f} руб.")
